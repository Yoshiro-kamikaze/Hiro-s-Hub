local function RefreshChar()
    Char = LP.Character
    if not Char then return false end
    HRP = Char:FindFirstChild("HumanoidRootPart")
    Hum = Char:FindFirstChildOfClass("Humanoid")
    return HRP ~= nil and Hum ~= nil
end

local function IsEnemy(m)
    if not m or not m:IsA("Model") or Players:GetPlayerFromCharacter(m) then return false end
    local ehum = m:FindFirstChildOfClass("Humanoid")
    return ehum and ehum.Health > 0 and m:FindFirstChild("HumanoidRootPart")
end

