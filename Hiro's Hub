-- // MOVEMENT & AUTO-FARM HEARTBEAT \\ --
RunService.Heartbeat:Connect(function(delta)
    if not S.Running or not RefreshChar() then return end

    local target = GetBestTarget()
    if not target then return end

    local tHRP = target:FindFirstChild("HumanoidRootPart")
    if not tHRP then return end

    local tPos = tHRP.Position
    local targetPos
    local height = S.PosHeight

    if S.PosMode == "Top" then
        targetPos = tPos + Vector3.new(0, height, 0)

    elseif S.PosMode == "Side" then
        targetPos = (tHRP.CFrame * CFrame.new(0, height, S.PosDistance)).Position

    elseif S.PosMode == "Orbit" then
        local angle = tick() * 3
        targetPos = tPos + Vector3.new(
            math.cos(angle) * S.PosDistance,
            height,
            math.sin(angle) * S.PosDistance
        )

    elseif S.PosMode == "Cluster" then
        local bestPos = GetBestChainPosition()

        if bestPos then
            targetPos = bestPos + Vector3.new(0, height + 3, 0)
        else
            targetPos = tPos + Vector3.new(0, height, 0)
        end
    end

    if targetPos then
        HRP.CFrame = CFrame.new(targetPos)
        HRP.Velocity = Vector3.zero
    end
end)

