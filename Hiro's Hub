local function GetBestTarget()  
    if CurrentTarget and CurrentTarget.Parent and IsEnemy(CurrentTarget) then 
        local eHum = CurrentTarget:FindFirstChildOfClass("Humanoid")
        if eHum and eHum.Health > 0 then 
            return CurrentTarget 
        end
    end

    local closest, bestDist = nil, math.huge
    local dungeonEnemies = workspace:FindFirstChild("DungeonEnemies")
    local potentialTargets = {}

    if dungeonEnemies then
        for _, room in ipairs(dungeonEnemies:GetChildren()) do
            for _, v in ipairs(room:GetChildren()) do
                if IsEnemy(v) then
                    table.insert(potentialTargets, v)
                end
            end
        end
    end

    if #potentialTargets == 0 then
        for _, v in ipairs(workspace:GetDescendants()) do
            if IsEnemy(v) then
                table.insert(potentialTargets, v)
            end
        end
    end

    for _, mob in ipairs(potentialTargets) do
        local d = (HRP.Position - mob.HumanoidRootPart.Position).Magnitude
        if d < bestDist then
            bestDist = d
            closest = mob
        end
    end

    CurrentTarget = closest
    return closest
end


