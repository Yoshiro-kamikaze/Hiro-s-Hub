local function GetBestChainPosition()
    local enemiesFolder = workspace:FindFirstChild("DungeonEnemies")
    if not enemiesFolder then return nil end

    local mobs = {}

    for _, room in ipairs(enemiesFolder:GetChildren()) do
        for _, mob in ipairs(room:GetChildren()) do
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hrp and hum and hum.Health > 0 then
                table.insert(mobs, mob)
            end
        end
    end

    if #mobs == 0 then return nil end

    local BEST_POS = nil
    local BEST_SCORE = -math.huge

    for _, mob in ipairs(mobs) do
        local origin = mob.HumanoidRootPart.Position

        local nearby = 0
        local totalDist = 0

        for _, other in ipairs(mobs) do
            if other ~= mob then
                local dist = (origin - other.HumanoidRootPart.Position).Magnitude
                
                if dist <= 30 then
                    nearby += 1
                    totalDist += dist
                end
            end
        end

        -- 🔥 scoring system (GOD CHAIN)
        local densityScore = nearby * 5
        local distanceScore = nearby > 0 and (100 / (totalDist / nearby)) or 0
        local finalScore = densityScore + distanceScore

        if finalScore > BEST_SCORE then
            BEST_SCORE = finalScore
            BEST_POS = origin
        end
    end

    return BEST_POS
end
